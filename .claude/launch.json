{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nfl-hype-dashboard (dev)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["app/app.py"],
      "port": 8050
    },
    {
      "name": "nfl-hype-dashboard (gunicorn)",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["app.app:server", "--bind", "0.0.0.0:8050", "--workers", "1", "--timeout", "120"],
      "port": 8050
    }
  ]
}
